"""
asciidoc-link searches the static documents for references to custom
resources and links them into the auto-generated documentation.
"""

# pylint: disable=invalid-name
# pylint: disable=line-too-long

import argparse
import glob
import os.path
import re
import sys

# Native types are not documented, so where the docs refer to children e.g.
# couchbaseclusters.spec.servers.pod.spec.nodeSelector we need to ignore these
# instead linking them to an effective reference that links to the Kubernetes
# docs i.e. couchbaseclusters.spec.servers.pod.
NATIVE_TYPES = [
    'couchbaseclusters.spec.backup.nodeSelector',
    'couchbaseclusters.spec.backup.resources',
    'couchbaseclusters.spec.backup.selector',
    'couchbaseclusters.spec.logging.audit.garbageCollection.sidecar.resources',
    'couchbaseclusters.spec.logging.server.sidecar.resources',
    'couchbaseclusters.spec.monitoring.prometheus.resources',
    'couchbaseclusters.spec.networking.adminConsoleServiceTemplate',
    'couchbaseclusters.spec.networking.exposedFeatureServiceTemplate',
    'couchbaseclusters.spec.security.rbac.selector',
    'couchbaseclusters.spec.securityContext',
    'couchbaseclusters.spec.servers.env',
    'couchbaseclusters.spec.servers.envFrom',
    'couchbaseclusters.spec.servers.pod',
    'couchbaseclusters.spec.servers.resources',
    'couchbaseclusters.spec.volumeClaimTemplates',
    'couchbaseclusters.spec.xdcr.remoteClusters.replications.selector',
    'couchbasescopes.spec.collections.selector',
    'couchbasescopegroups.spec.collections.selector',
    'couchbasebuckets.spec.scopes.selector',
    'couchbaseephemeralbuckets.spec.scopes.selector',
]

def get_effective_reference(reference):
    """
    Transform references that address Kubernetes native types into
    something that should be documented.
    """

    for native_type in NATIVE_TYPES:
        if reference.startswith(native_type):
            return native_type

    return reference


def get_linker_map(autogenerated_paths):
    """
    Build a map from JSON path (what's in the docs) to asciidoc xref.
    """

    links = {}

    for autogenerated_path in autogenerated_paths:
        basename = os.path.basename(autogenerated_path)

        with open(autogenerated_path, encoding="utf-8") as autogenerated_file:
            lines = autogenerated_file.readlines()

        for line in lines:
            matches = re.match(r'=+ (.*)', line)
            if not matches:
                continue

            json_path = matches.group(1)

            # Anchors are all converted to lower case.
            asciidoc_anchor = json_path.lower()

            # Some characters are converted to hyphens
            asciidoc_anchor = re.sub(r'\.', '-', asciidoc_anchor)

            asciidoc_xref = f'resource/{basename}#{asciidoc_anchor}'

            links[json_path] = asciidoc_xref

    return links


def main():
    """
    Find all auto generated attributes and then search the static docs for
    references.  If they exist, link in a corss-reference, if not warn about it.
    """

    parser = argparse.ArgumentParser()
    parser.add_argument('--dry-run', action='store_true')
    args = parser.parse_args()

    autogenerated_paths = glob.glob('docs/user/modules/ROOT/pages/resource/*.adoc')

    links = get_linker_map(autogenerated_paths)

    # Go through each non-autogenerated file and look for JSON path style references,
    # patching them to the correct location.
    authored_paths = glob.glob('docs/user/modules/ROOT/pages/*')

    for authored_path in authored_paths:
        # Calculate the links in each file.
        try:
            with open(authored_path, encoding="utf-8") as authored_file:
                authored_content = authored_file.read()
        except IsADirectoryError:
            continue

        references = re.findall(r'`(couchbase[a-z]+(?:\.\w+)+)`', authored_content)

        unique_references = frozenset(references)

        # Validate the links exist...
        for unique_reference in unique_references:
            effective_reference = get_effective_reference(unique_reference)

            if effective_reference not in links:
                print(f'reference {unique_reference} in {authored_path} does not have a target')
                sys.exit(1)

            # Consider any existing links, as the layout may have changed, and anything that hasn't been linked yet.
            authored_content = re.sub(rf'(xref:[^\[]+\[)?`{unique_reference}`\]?', f'xref:{links[effective_reference]}[`{unique_reference}`]', authored_content)

        if args.dry_run:
            continue

        linked_path = f'docs/user/modules/ROOT/pages/{os.path.basename(authored_path)}'

        with open(linked_path, 'w', encoding="utf-8") as linked_file:
            linked_file.write(authored_content)


if __name__ == '__main__':
    main()

