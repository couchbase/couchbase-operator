pipeline {
  agent {
    label 'docker'
  }

  environment {
    GOBIN = "${env.WORKSPACE}/bin"
    GOVERSION = '1.22.1'
    NODEVERSION = '16.0.0'
    GOPATH = "${env.WORKSPACE}/gopath"
    PATH = "${env.GOBIN}:${env.WORKSPACE}/go/bin:${env.WORKSPACE}/node-v${env.NODEVERSION}-linux-x64/bin:${PATH}"
    MAKEFLAGS = "--no-builtin-rules"
  }

  stages {
    stage('Go Install') {
      steps {
        sh 'wget -q -O- https://dl.google.com/go/go${GOVERSION}.linux-amd64.tar.gz | tar xz'
        sh 'touch go/go.mod'
      }
    }
    stage('Node.js Install') {
      steps {
        sh 'wget -q -O- https://nodejs.org/dist/v${NODEVERSION}/node-v${NODEVERSION}-linux-x64.tar.xz | tar xJ'
      }
    }
    stage('Post Checkout') {
      steps {
        sh 'make touch-generated'
      }
    }
    stage('Go Lint') {
      steps {
        sh 'make lint'
      }
    }
    stage('Python Lint') {
      steps {
        sh 'python3 -m venv venv'
        sh '. venv/bin/activate && pip3 install -r scripts/requirements.txt'
        sh '. venv/bin/activate && make lint-python'
      }
    }
    stage('Build Developer') {
      steps {
        sh 'make touch-generated all'
      }
    }
    stage('Build Release') {
      steps {
        sh 'make dist-lite'
      }
    }
    stage('Unit Test') {
      steps {
        sh 'make test-unit'
      }
    }
    stage('Documentation') {
      steps {
        sh 'make docs-lint'
      }
    }
  }

  post {
    always {
      cleanWs()
    }
  }
}
