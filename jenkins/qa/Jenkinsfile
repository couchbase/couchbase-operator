/**
 * One pipeline to rule them all...
 * Warning, this belongs to development and must be fast and stable, do not modify without
 * good reason!
 */
pipeline {
  agent any

  options {
    timestamps()

    // Discard any stale builds so we don't fill up the disk.
    buildDiscarder(
      logRotator(
        artifactDaysToKeepStr: '30',
        artifactNumToKeepStr: '50',
        daysToKeepStr: '30',
        numToKeepStr: '50',
      )
    )

    // We only have a single cluster for now, control concurrency with other runs of this
    // job, or another job with a reservation on a global lockable resource.
    lock resource: 'gke-cluster-couchbase-operator-certification'
  }

  parameters {
    string(name: 'refspec', defaultValue: 'refs/heads/master', description: 'Gerrit ref spec of your source tree')
    string(name: 'server_image', defaultValue: 'couchbase/server:7.0.0', , description: 'Version of Couchbase to test')
    string(name: 'server_image_upgrade', defaultValue: 'couchbase/server:6.6.2', description: 'Version of Couchbase to upgrade from')
    string(name: 'backup_image', defaultValue: 'couchbase/operator-backup:1.1.0', description: 'Version of the Couchbase backup image to test')
    string(name: 'exporter_image', defaultValue: 'couchbase/exporter:1.0.5', description: 'Version of the Prometheus exporter to test')
    string(name: 'exporter_image_upgrade', defaultValue: 'couchbase/exporter:1.0.4', description: 'Version of the Prometheus exporter to upgrade from')
    string(name: 'logging_image', defaultValue: 'couchbase/fluent-bit:1.1.0', description: 'Version of the log shipping sidecar to test')
    string(name: 'logging_image_upgrade', defaultValue: 'couchbase/fluent-bit:1.0.4', description: 'Version of the log shipping sidecar to upgrade from')
    string(name: 'mobile_image', defaultValue: 'couchbase/sync-gateway:2.8.2-enterprise', description: 'Version of Sync-Gateway to test')
    choice(name: 'bucket_type', choices: ['couchbase', 'ephemeral', 'memcached'], description: 'Bucket type to test with, for tests where bucket type is dynamic')
    choice(name: 'compression_mode', choices: ['passive', 'active', 'off'], description: 'Bucket compression to test with, for tests where compression is dynamic')
    choice(name: 'suites', choices: ['', 'p0', 'p0 p1'], description: 'Any additional suites to run (validation and sanity are mandarory)')
    string(name: 'features', defaultValue: '', description: 'Much like a suite, these feature sets allow functional area testing e.g. "backup"')
    string(name: 'tests', defaultValue: '', description: 'Any custom tests to run, this is a space delimited list of tests names e.g. "TestCreateCluster TestCreateBucketCluster"')
  }

  environment {
    GOVERSION = "1.16.3"
    GOROOT = "${env.WORKSPACE}/go"
    PATH = "${env.WORKSPACE}/go/bin:${env.WORKSPACE}/kind/bin:${env.WORKSPACE}/google-cloud-sdk/bin:$PATH"
    DOCKER_CREDENTIALS = credentials('dockerhub-couchbaseqe')
    GCLOUD_SERVICE_TOKEN = credentials('google-cloud-couchbase-operator')
    AWS_CREDENTIALS = credentials('aws-simon')
    KIND_VERSION = "0.11.0"
  }

  stages {
    stage('Build Name') {
      steps {
        // The build name must be unique, or the JUnit trend will crap out.
        buildName "#${BUILD_NUMBER} ${sh(script: 'git log --oneline --format=%B HEAD | head -n 1', returnStdout: true)}"
        buildDescription "Patchset: ${params.refspec.split('/').last()}"
      }
    }

    stage('Install Go') {
      steps {
        sh 'wget -q -O- https://dl.google.com/go/go${GOVERSION}.linux-amd64.tar.gz | tar xz'
      }
    }

    stage('Install Google Cloud SDK') {
      steps {
        sh 'wget -q -O- https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-sdk-315.0.0-linux-x86_64.tar.gz | tar xz'
        sh 'gcloud components install kubectl'
        sh 'gcloud auth activate-service-account couchbase-operator@couchbase-engineering.iam.gserviceaccount.com --project couchbase-engineering --key-file ${GCLOUD_SERVICE_TOKEN}'
        sh 'KUBECONFIG=config gcloud container clusters get-credentials couchbase-operator-ci-certification --region us-east1'
      }
    }

    stage('Install Kind') {
      steps {
        sh 'mkdir -p kind/bin'
        sh 'curl -Lo kind/bin/kind https://kind.sigs.k8s.io/dl/v${KIND_VERSION}/kind-linux-amd64'
        sh 'chmod +x kind/bin/kind'
      }
    }

    stage('Build Binaries') {
      steps {
        sh 'make touch-generated && make'
      }
    }

    stage('Build Container Images') {
      steps {
        sh 'docker login -u ${DOCKER_CREDENTIALS_USR} -p ${DOCKER_CREDENTIALS_PSW}'
        sh 'make container-public -e DOCKER_USER=${DOCKER_CREDENTIALS_USR} DOCKER_TAG=${GIT_COMMIT}'
        sh 'make certification-container-public -e DOCKER_USER=${DOCKER_CREDENTIALS_USR} DOCKER_TAG=${GIT_COMMIT}'
      }

      post {
        always {
          // Remove old docker images now, this stops disk from filling up and minimises risk
          // of this not being called due to a job cancellation.
          sh 'make container-clean -e DOCKER_USER=${DOCKER_CREDENTIALS_USR} DOCKER_TAG=${GIT_COMMIT}'
        }
      }
    }

    stage('Validation Test') {
      matrix {
        axes {
          axis {
            name 'version'
            values 'v1.18.8', 'v1.19.1', 'v1.20.0', 'v1.21.1', 'v1.22.0'
          }
        }

        stages {
          stage('Validation Test') {
            steps {
              sh 'kind create cluster --name ${version} --image kindest/node:${version} --kubeconfig kubeconfig.${version}'
              sh 'KUBECONFIG=${WORKSPACE}/kubeconfig.${version} ./build/bin/cao \
                certify \
                --image ${DOCKER_CREDENTIALS_USR}/couchbase-operator-certification:${GIT_COMMIT} \
                --timeout 10m \
                -- \
                -suite validation \
                -suite-suffix ${version} \
                -operator-image ${DOCKER_CREDENTIALS_USR}/couchbase-operator:${GIT_COMMIT} \
                -admission-image ${DOCKER_CREDENTIALS_USR}/couchbase-operator-admission:${GIT_COMMIT}'
              sh 'tar xf couchbase-platform-certification.tar.bz2'
            }

            post {
              always {
                sh 'kind delete cluster --name ${version}'
              }
            }
          }
        }
      }
    }

    stage('Acceptance Test') {
      steps {
        // Warn if something went wrong, but don't fail, it's probably just an unstable test/platform.
        warnError('Suite failed') {
          sh "KUBECONFIG=${WORKSPACE}/config ./build/bin/cao \
            certify \
            --clean \
            --parallel 8 \
            --image \${DOCKER_CREDENTIALS_USR}/couchbase-operator-certification:${GIT_COMMIT} \
            -- \
            -suite sanity \
            ${params.suites.split().collect{s -> '-suite ' + s}.join(' ')} \
            ${params.features.split().collect{s -> '-suite ' + s}.join(' ')} \
            ${params.tests.split().collect{s -> '-test ' + s}.join(' ')} \
            -platform-type kubernetes \
            -operator-image \${DOCKER_CREDENTIALS_USR}/couchbase-operator:\${GIT_COMMIT} \
            -admission-image \${DOCKER_CREDENTIALS_USR}/couchbase-operator-admission:\${GIT_COMMIT} \
            -mobile-image \${mobile_image} \
            -server-image \${server_image} \
            -server-image-upgrade \${server_image_upgrade} \
            -exporter-image \${exporter_image} \
            -exporter-image-upgrade \${exporter_image_upgrade} \
            -backup-image \${backup_image} \
            -logging-image \${logging_image} \
            -logging-image-upgrade \${logging_image_upgrade} \
            -storage-class standard-rwo \
            -bucket-type \${bucket_type} \
            -compression-mode \${compression_mode} \
            -registry https://index.docker.io/v1/,\${DOCKER_CREDENTIALS_USR},\${DOCKER_CREDENTIALS_PSW} \
            -collect-logs \
            -s3-access-key \${AWS_CREDENTIALS_USR} \
            -s3-secret-id \${AWS_CREDENTIALS_PSW}"
        }
        sh 'tar xf couchbase-platform-certification.tar.bz2'
      }
    }
  }

  post {
    always {
      // Save JUnit results, this is what we will review.
      junit 'artifacts/*.xml'

      // Archive any logs as an artifact, these may be needed to debug an issue.
      sh 'tar czf logs.tar.gz artifacts/logs'
      archiveArtifacts artifacts: 'logs.tar.gz', fingerprint: true

      // Clean up the workspace to free disk space.
      cleanWs()
    }
  }
}
