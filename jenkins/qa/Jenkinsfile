/**
 * One pipeline to rule them all...
 * Reegardless of the platform all run the same, the test framework accepts
 * configuration for two clusters, and it runs the tests against them.  This
 * should not be run by itself as it provides no locking around the use of
 * configuration.
 */
pipeline {
  agent {
    label 'k8'
  }

  options {
    timestamps()

    // Don't use all the disk, these servers aren't monitored with Nagios or anything.
    buildDiscarder(
      logRotator(
        artifactDaysToKeepStr: '7',
        artifactNumToKeepStr: '10',
        daysToKeepStr: '7',
        numToKeepStr: '10',
      )
    )

    // We only have a single cluster for now.
    disableConcurrentBuilds()
  }

  parameters {
    string(name: 'refspec', defaultValue: 'refs/heads/master')
    string(name: 'server_image', defaultValue: 'couchbase/server:6.5.1')
    string(name: 'server_image_upgrade', defaultValue: 'couchbase/server:6.6.0')
    string(name: 'backup_image', defaultValue: 'couchbase/operator-backup:6.5.1-111')
    string(name: 'exporter_image', defaultValue: 'couchbase/exporter:1.0.0')
    string(name: 'exporter_image_upgrade', defaultValue: 'couchbase/exporter:1.0.2')
    string(name: 'mobile_image', defaultValue: 'couchbase/sync-gateway:2.8.0-enterprise')
    string(name: 'platform', defaultValue: 'kubernetes')
    string(name: 'storage_class', defaultValue: 'dynamic-bound')
    string(name: 'bucket_type', defaultValue: 'couchbase')
    string(name: 'compression_mode', defaultValue: 'passive')
    booleanParam(name: 'validation', defaultValue: true)
    booleanParam(name: 'sanity', defaultValue: true)
    booleanParam(name: 'p0', defaultValue: false)
    booleanParam(name: 'p1', defaultValue: false)
    booleanParam(name: 'custom', defaultValue: false)
  }

  environment {
    GOVERSION = '1.13.3'
    GOROOT = "${env.WORKSPACE}/go"
    PATH = "${env.WORKSPACE}/go/bin:$PATH"
    DOCKER_CREDENTIALS = credentials('couchbaseqe-dockerhub')
    GITLAB_CREDENTIALS = credentials('couchbaseqe-gitlab')
    GCLOUD_SERVICE_TOKEN = credentials('gcloud-service-token-operator-dev')
    LOG_DIR = "/data/operator-pipeline/${env.BUILD_NUMBER}"
  }

  stages {
    stage('Go Install') {
      steps {
        sh "wget -q -O- https://dl.google.com/go/go${env.GOVERSION}.linux-amd64.tar.gz | tar xz"
      }
    }

    stage('Google Cloud Install') {
      steps {
        sh 'wget -q -O- https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-sdk-230.0.0-linux-x86_64.tar.gz | tar xz'
        sh './google-cloud-sdk/bin/gcloud components install kubectl'
        sh "./google-cloud-sdk/bin/gcloud auth activate-service-account couchbase-operator@couchbase-engineering.iam.gserviceaccount.com --project couchbase-engineering --key-file ${env.GCLOUD_SERVICE_TOKEN}"
        sh 'KUBECONFIG=config1 ./google-cloud-sdk/bin/gcloud container clusters get-credentials couchbase-operator-ci --region us-east1'
        sh 'KUBECONFIG=config2 ./google-cloud-sdk/bin/gcloud container clusters get-credentials couchbase-operator-ci --region us-west1'
      }
    }

    stage('Post Checkout') {
      steps {
        sh 'make touch-generated'
      }
    }

    stage('Build') {
      steps {
        sh 'make'
      }
    }

    stage('Build Docker') {
      steps {
        sh "docker login -u ${env.DOCKER_CREDENTIALS_USR} -p ${env.DOCKER_CREDENTIALS_PSW}"
        sh "make container-public -e DOCKER_USER=${env.DOCKER_CREDENTIALS_USR} DOCKER_TAG=`git rev-parse FETCH_HEAD`"
      }
    }

    // All of these test stages are exactly the same.  With a matrix build
    // iterating over a list of suites, you only need to define it once.
    // Appears to need the declarative pipeline plugin version >= 1.5.

    stage('Test Validation') {
      when {
        expression {
          params.validation
        }
      }
      steps {
        sh 'rm -rf test/e2e/logs test/e2e/*.xml'

        // Newer versions can use the warnError closure, which can flag
        // individual stages as broken, not the whole build.  That said
        // none of this would be necessary if tests were stable...

        script {
          try {
            sh "go test github.com/couchbase/couchbase-operator/test/e2e -run TestOperator -v -race -timeout 12h -parallel 8 -args -platform-type ${params.platform} -operator-image ${env.DOCKER_CREDENTIALS_USR}/couchbase-operator:`git rev-parse FETCH_HEAD` -admission-image ${env.DOCKER_CREDENTIALS_USR}/couchbase-operator-admission:`git rev-parse FETCH_HEAD` -mobile-image ${params.mobile_image} -server-image ${params.server_image} -server-image-upgrade ${params.server_image_upgrade} -exporter-image ${params.exporter_image} -exporter-image-upgrade ${params.exporter_image_upgrade} -backup-image ${params.backup_image} -suite TestCRDValidation -storage-class ${params.storage_class} -bucket-type ${params.bucket_type} -compression-mode ${params.compression_mode} -cluster ${env.WORKSPACE}/config1 -cluster ${env.WORKSPACE}/config2 -registry https://index.docker.io/v1/,${env.DOCKER_CREDENTIALS_USR},${env.DOCKER_CREDENTIALS_PSW} -registry https://registry.gitlab.com/,${env.GITLAB_CREDENTIALS_USR},${env.GITLAB_CREDENTIALS_PSW} -collect-logs"
          }
          catch (e) {
            currentBuild.result = 'UNSTABLE'
          }
        }
      }
      post {
        always {
          junit 'test/e2e/*.xml'
          sh 'tar czf validation.tar.gz -C test/e2e/logs --exclude=\'*.zip\' .'
          archiveArtifacts artifacts: 'validation.tar.gz', fingerprint: true
        }
      }
    }

    stage('Test Sanity') {
      when {
        expression {
          params.sanity
        }
      }
      steps {
        sh 'rm -rf test/e2e/logs test/e2e/*.xml'
        script {
          try {
            sh "go test github.com/couchbase/couchbase-operator/test/e2e -run TestOperator -v -race -timeout 12h -parallel 8 -args -platform-type ${params.platform} -operator-image ${env.DOCKER_CREDENTIALS_USR}/couchbase-operator:`git rev-parse FETCH_HEAD` -admission-image ${env.DOCKER_CREDENTIALS_USR}/couchbase-operator-admission:`git rev-parse FETCH_HEAD` -mobile-image ${params.mobile_image} -server-image ${params.server_image} -server-image-upgrade ${params.server_image_upgrade} -exporter-image ${params.exporter_image} -exporter-image-upgrade ${params.exporter_image_upgrade} -backup-image ${params.backup_image} -suite TestSanity -storage-class ${params.storage_class} -bucket-type ${params.bucket_type} -compression-mode ${params.compression_mode} -cluster ${env.WORKSPACE}/config1 -cluster ${env.WORKSPACE}/config2 -registry https://index.docker.io/v1/,${env.DOCKER_CREDENTIALS_USR},${env.DOCKER_CREDENTIALS_PSW} -registry https://registry.gitlab.com/,${env.GITLAB_CREDENTIALS_USR},${env.GITLAB_CREDENTIALS_PSW} -collect-logs"
          }
          catch (e) {
            currentBuild.result = 'UNSTABLE'
          }
        }
      }
      post {
        always {
          junit 'test/e2e/*.xml'
          sh 'tar czf sanity.tar.gz -C test/e2e/logs --exclude=\'*.zip\' .'
          archiveArtifacts artifacts: 'sanity.tar.gz', fingerprint: true
        }
      }
    }

    stage('Test P0') {
      when {
        expression {
          params.p0
        }
      }
      steps {
        sh 'rm -rf test/e2e/logs test/e2e/*.xml'
        script {
          try {
            sh "go test github.com/couchbase/couchbase-operator/test/e2e -run TestOperator -v -race -timeout 12h -parallel 8 -args -platform-type ${params.platform} -operator-image ${env.DOCKER_CREDENTIALS_USR}/couchbase-operator:`git rev-parse FETCH_HEAD` -admission-image ${env.DOCKER_CREDENTIALS_USR}/couchbase-operator-admission:`git rev-parse FETCH_HEAD` -mobile-image ${params.mobile_image} -server-image ${params.server_image} -server-image-upgrade ${params.server_image_upgrade} -exporter-image ${params.exporter_image} -exporter-image-upgrade ${params.exporter_image_upgrade} -backup-image ${params.backup_image} -suite TestP0 -storage-class ${params.storage_class} -bucket-type ${params.bucket_type} -compression-mode ${params.compression_mode} -cluster ${env.WORKSPACE}/config1 -cluster ${env.WORKSPACE}/config2 -registry https://index.docker.io/v1/,${env.DOCKER_CREDENTIALS_USR},${env.DOCKER_CREDENTIALS_PSW} -registry https://registry.gitlab.com/,${env.GITLAB_CREDENTIALS_USR},${env.GITLAB_CREDENTIALS_PSW} -collect-logs"
          }
          catch (e) {
            currentBuild.result = 'UNSTABLE'
          }
        }
      }
      post {
        always {
          junit 'test/e2e/*.xml'
          sh 'tar czf p0.tar.gz -C test/e2e/logs --exclude=\'*.zip\' .'
          archiveArtifacts artifacts: 'p0.tar.gz', fingerprint: true
        }
      }
    }

    stage('Test P1') {
      when {
        expression {
          params.p1
        }
      }
      steps {
        sh 'rm -rf test/e2e/logs test/e2e/*.xml'
        script {
          try {
            sh "go test github.com/couchbase/couchbase-operator/test/e2e -run TestOperator -v -race -timeout 12h -parallel 8 -args -platform-type ${params.platform} -operator-image ${env.DOCKER_CREDENTIALS_USR}/couchbase-operator:`git rev-parse FETCH_HEAD` -admission-image ${env.DOCKER_CREDENTIALS_USR}/couchbase-operator-admission:`git rev-parse FETCH_HEAD` -mobile-image ${params.mobile_image} -server-image ${params.server_image} -server-image-upgrade ${params.server_image_upgrade} -exporter-image ${params.exporter_image} -exporter-image-upgrade ${params.exporter_image_upgrade} -backup-image ${params.backup_image} -suite TestP1 -storage-class ${params.storage_class} -bucket-type ${params.bucket_type} -compression-mode ${params.compression_mode} -cluster ${env.WORKSPACE}/config1 -cluster ${env.WORKSPACE}/config2 -registry https://index.docker.io/v1/,${env.DOCKER_CREDENTIALS_USR},${env.DOCKER_CREDENTIALS_PSW} -registry https://registry.gitlab.com/,${env.GITLAB_CREDENTIALS_USR},${env.GITLAB_CREDENTIALS_PSW} -collect-logs"
          }
          catch (e) {
            currentBuild.result = 'UNSTABLE'
          }
        }
      }
      post {
        always {
          junit 'test/e2e/*.xml'
          sh 'tar czf p1.tar.gz -C test/e2e/logs --exclude=\'*.zip\' .'
          archiveArtifacts artifacts: 'p1.tar.gz', fingerprint: true
        }
      }
    }

    stage('Test Custom') {
      when {
        expression {
          params.custom
        }
      }
      steps {
        sh 'rm -rf test/e2e/logs test/e2e/*.xml'
        script {
          try {
            sh "go test github.com/couchbase/couchbase-operator/test/e2e -run TestOperator -v -race -timeout 12h -parallel 8 -args -platform-type ${params.platform} -operator-image ${env.DOCKER_CREDENTIALS_USR}/couchbase-operator:`git rev-parse FETCH_HEAD` -admission-image ${env.DOCKER_CREDENTIALS_USR}/couchbase-operator-admission:`git rev-parse FETCH_HEAD` -mobile-image ${params.mobile_image} -server-image ${params.server_image} -server-image-upgrade ${params.server_image_upgrade} -exporter-image ${params.exporter_image} -exporter-image-upgrade ${params.exporter_image_upgrade} -backup-image ${params.backup_image} -suite TestCustom -storage-class ${params.storage_class} -bucket-type ${params.bucket_type} -compression-mode ${params.compression_mode} -cluster ${env.WORKSPACE}/config1 -cluster ${env.WORKSPACE}/config2 -registry https://index.docker.io/v1/,${env.DOCKER_CREDENTIALS_USR},${env.DOCKER_CREDENTIALS_PSW} -registry https://registry.gitlab.com/,${env.GITLAB_CREDENTIALS_USR},${env.GITLAB_CREDENTIALS_PSW} -collect-logs"
          }
          catch (e) {
            currentBuild.result = 'UNSTABLE'
          }
        }
      }
      post {
        always {
          sh 'tar czf custom.tar.gz -C test/e2e/logs --exclude=\'*.zip\' .'
          archiveArtifacts artifacts: 'custom.tar.gz', fingerprint: true
        }
      }
    }
  }

  post {
    always {
      cleanWs()
    }
  }
}
